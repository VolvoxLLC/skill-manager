{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-skilldeck",
      "detail": "Generate the Xcode project and build the SkillDeck macOS app (Debug).",
      "type": "shell",
      "command": "xcodegen generate && xcodebuild -project SkillDeck.xcodeproj -scheme SkillDeck -configuration Debug -destination 'platform=macOS' -derivedDataPath DerivedData build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": {
        "owner": "swift",
        "source": "xcodebuild",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^(.+?):(\\d+):(\\d+):\\s+(warning|error|note):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    },
    {
      "label": "test-skilldeckkit",
      "detail": "Run the SkillDeckKit Swift package test suite.",
      "type": "shell",
      "command": "swift test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": {
        "owner": "swift",
        "source": "swift-test",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^(.+?):(\\d+):(\\d+):\\s+(warning|error|note):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    }
  ]
}
